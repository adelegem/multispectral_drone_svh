# Zenodo raster downloads (10.5281/zenodo.17089161) — too large for git
data/raster_images/

# Intermediate/derived outputs
data_out/

# Publication figure outputs from figures-for-publication.R
maps_graphs/

# {targets} pipeline cache. _targets.R / _targets.yaml are the pipeline
# definition and must stay tracked.
_targets/

# R / RStudio
.Rhistory
.Rapp.history
.RData
.Ruserdata
.Rproj.user/
Rplots.pdf

# Knitr / R Markdown render artifacts (chunk caches + per-doc figure dirs)
*_cache/
*_files/

# Local environment / secrets — never commit
.Renviron
.Rprofile.local
.env

# Editor swap/backup files
*~
*.swp
*.swo

# macOS
.DS_Store

# Transient logs (download progress, run output, render output)
*.log

# Manuscript drafts — kept outside source control
*.docx

# Transient workflow-figure drafts (the canonical workflow figure is built
# inline by make_figure_workflow() in funx.R and embedded in report.html).
reports/workflow_*.png
reports/workflow_*.mmd

# Release artifacts built by tools/pack_cache.R — uploaded to GitHub release,
# not tracked here.
_targets_lite.tar.gz
